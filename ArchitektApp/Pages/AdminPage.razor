@page "/admin"
@using Core.Models
@using Blazored.LocalStorage
@using ArchitektApp.Service
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject HttpClient Http
@inject FileService FileService

<PageTitle>Admin Dashboard</PageTitle>

<!-- =====================
     DASHBOARD LAYOUT
     Sidebar til venstre med sektionsknapper, hovedindhold til højre
     ===================== -->
<div class="admin-layout">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="admin-logo">JOHAN BERTHELSEN, ARKITEKT MAA</div>
        <p class="admin-velkommen">Velkommen, @brugerNavn</p>

        <!-- Sektionsknapper — klik skifter den aktive sektion uden at genindlæse siden -->
        <nav class="admin-nav">
            <button class="admin-nav-btn @(aktivSektion == "henvendelser" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("henvendelser")'>
                Henvendelser
            </button>
            <button class="admin-nav-btn @(aktivSektion == "medarbejdere" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("medarbejdere")'>
                Medarbejdere
            </button>
            <button class="admin-nav-btn @(aktivSektion == "projekter" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("projekter")'>
                Projekter
            </button>
            <button class="admin-nav-btn @(aktivSektion == "kalender" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("kalender")'>
                Kalender
            </button>
        </nav>

        <!-- Log ud og tilbage til forside i bunden af sidebaren -->
        <div class="admin-sidebar-footer">
            <button class="admin-nav-btn" @onclick='() => Navigation.NavigateTo("/")'>← Forside</button>
            <button class="admin-nav-btn admin-log-ud" @onclick="LogUd">Log ud</button>
        </div>
    </aside>

    <!-- HOVEDINDHOLD -->
    <main class="admin-main">

        <!-- =====================
             HENVENDELSER SEKTION
             Viser alle indkomne bookinger fra kunder i en tabel
             ===================== -->
        @if (aktivSektion == "henvendelser")
        {
            <h2 class="admin-sektion-titel">Henvendelser</h2>

            @if (henvendelser == null)
            {
                <!-- Vises mens henvendelser hentes fra serveren -->
                <p>Henter henvendelser...</p>
            }
            else if (henvendelser.Count == 0)
            {
                <p class="admin-tom">Ingen henvendelser endnu.</p>
            }
            else
            {
                <table class="admin-tabel">
                    <thead>
                        <tr>
                            <th>NAVN</th>
                            <th>EMAIL</th>
                            <th>TELEFON</th>
                            <th>ØNSKET DATO</th>
                            <th>BESKRIVELSE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in henvendelser)
                        {
                            <tr>
                                <td>@h.Kundenavn</td>
                                <td>@h.Kundemail</td>
                                <td>@h.KundeTlf</td>
                                <!-- Formaterer datoen til dansk format dag/måned/år og klokkeslæt -->
                                <td>@h.OensketDato.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@h.Beskrivelse</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- =====================
             MEDARBEJDERE SEKTION (ikke implementeret endnu)
             ===================== -->
        @if (aktivSektion == "medarbejdere")
        {
            <h2 class="admin-sektion-titel">Medarbejdere</h2>
            <p class="admin-tom">Kommer snart.</p>
        }

        <!-- =====================
             PROJEKTER SEKTION
             Liste over projekter med mulighed for at oprette og redigere
             ===================== -->
        @if (aktivSektion == "projekter")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Projekter</h2>

                @if (!visFormular)
                {
                    <!-- Knap til at åbne opret-formularen -->
                    <button class="admin-knap" @onclick="VisOpretFormular">+ Opret nyt projekt</button>
                }
            </div>

            @if (!visFormular)
            {
                <!-- LISTE OVER EKSISTERENDE PROJEKTER -->
                @if (projekter == null)
                {
                    <p>Henter projekter...</p>
                }
                else if (projekter.Count == 0)
                {
                    <p class="admin-tom">Ingen projekter endnu.</p>
                }
                else
                {
                    <div class="admin-projekt-grid">
                        @foreach (var p in projekter)
                        {
                            <div class="admin-projekt-kort">
                                <!-- Viser det første billede som thumbnail, eller en grå flade hvis ingen billeder -->
                                <div class="admin-projekt-billede">
                                    @if (p.Billeder.Any())
                                    {
                                        <img src="@FileService.GetImageUrl(p.Billeder.First().FileName)" alt="@p.Navn" />
                                    }
                                    else
                                    {
                                        <span>Intet billede</span>
                                    }
                                </div>
                                <div class="admin-projekt-info">
                                    <p class="admin-projekt-navn">@p.Navn</p>
                                    <p class="admin-projekt-aar">@p.År</p>
                                    <div class="admin-projekt-knapper">
                                        <!-- Rediger-knap udfylder formularen med projektets data -->
                                        <button class="admin-knap-sek" @onclick="() => VisRedigerFormular(p)">Rediger</button>
                                        <button class="admin-knap-fare" @onclick="() => SletProjekt(p.Id)">Slet</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- =====================
                     OPRET / REDIGER FORMULAR
                     Samme formular bruges til både opret og rediger
                     erRedigering styrer om der sendes POST eller PUT
                     ===================== -->
                <div class="admin-formular">
                    <h3 class="admin-formular-titel">@(erRedigering ? "Rediger projekt" : "Nyt projekt")</h3>

                    <!-- Navn -->
                    <div class="admin-felt">
                        <label>NAVN</label>
                        <input type="text" @bind="aktivProjekt.Navn" placeholder="Projektnavn" />
                    </div>

                    <!-- Beskrivelse -->
                    <div class="admin-felt">
                        <label>BESKRIVELSE</label>
                        <textarea @bind="aktivProjekt.Beskrivelse" rows="4" placeholder="Beskriv projektet..."></textarea>
                    </div>

                    <!-- År -->
                    <div class="admin-felt">
                        <label>ÅR</label>
                        <input type="number" @bind="aktivProjekt.År" placeholder="2024" />
                    </div>

                    <!-- Billeder med beskrivelse — viser alle uploadede billeder med et beskrivelsesfelt under hvert -->
                    @if (aktivProjekt.Billeder.Any())
                    {
                        <div class="admin-felt">
                            <label>BILLEDER</label>
                            @foreach (var billede in aktivProjekt.Billeder.ToList())
                            {
                                <div class="admin-billede-item">
                                    <div class="admin-billede-thumb">
                                        <img src="@FileService.GetImageUrl(billede.FileName)" alt="billede" />
                                        <!-- Slet-knap fjerner billedet fra projektet og databasen -->
                                        <button class="admin-billede-slet" @onclick="() => FjernBillede(billede)">×</button>
                                    </div>
                                    <!-- Beskrivelsesfelt til hvert enkelt billede -->
                                    <input type="text"
                                           class="admin-billede-beskrivelse"
                                           @bind="billede.Beskrivelse"
                                           placeholder="Beskriv dette billede..." />
                                </div>
                            }
                        </div>
                    }

                    <!-- Upload nye billeder — hvert nyt billede tilføjes til listen ovenfor -->
                    <div class="admin-felt">
                        <label>TILFØJ BILLEDER</label>
                        <InputFile OnChange="UploadBilleder" multiple accept="image/*" />
                        @if (uploaderBilleder)
                        {
                            <p class="admin-upload-status">Uploader billeder...</p>
                        }
                    </div>

                    <!-- Statusbesked der vises efter gem forsøg -->
                    @if (!string.IsNullOrEmpty(projektStatus))
                    {
                        <p class="admin-status">@projektStatus</p>
                    }

                    <div class="admin-formular-knapper">
                        <button class="admin-knap" @onclick="GemProjekt">Gem projekt</button>
                        <!-- Annuller lukker formularen og viser listen igen -->
                        <button class="admin-knap-sek" @onclick="LukFormular">Annuller</button>
                    </div>
                </div>
            }
        }

        <!-- =====================
             KALENDER SEKTION (ikke implementeret endnu)
             ===================== -->
        @if (aktivSektion == "kalender")
        {
            <h2 class="admin-sektion-titel">Kalender</h2>
            <p class="admin-tom">Kommer snart.</p>
        }

    </main>
</div>

@code {
    // Styrer hvilken sektion der vises — starter med henvendelser
    private string aktivSektion = "henvendelser";

    private string brugerNavn = "";
    private int adminId = 0;

    // Core.Models.Booking bruges eksplicit fordi Booking.razor-komponenten ellers skaber navnekollision
    private List<Core.Models.Booking>? henvendelser;

    // =====================
    // PROJEKTER STATE
    // =====================

    private List<Projekt>? projekter;

    // Styrer om listen eller formularen vises i projekter-sektionen
    private bool visFormular = false;

    // True når man redigerer et eksisterende projekt, false når man opretter nyt
    private bool erRedigering = false;

    // Det projekt der aktuelt oprettes eller redigeres
    private Projekt aktivProjekt = new();

    private bool uploaderBilleder = false;
    private string projektStatus = "";

    // Kører automatisk når siden indlæses
    protected override async Task OnInitializedAsync()
    {
        // Henter brugeroplysninger fra LocalStorage
        var userRole = await LocalStorage.GetItemAsync<string>("userRole");
        brugerNavn = await LocalStorage.GetItemAsync<string>("userName") ?? "";
        adminId = await LocalStorage.GetItemAsync<int>("userId");

        // Hvis brugeren ikke er admin sendes de tilbage til forsiden
        if (userRole != "admin")
        {
            Navigation.NavigateTo("/");
            return;
        }

        // Henter alle henvendelser fra API'et
        henvendelser = await Http.GetFromJsonAsync<List<Core.Models.Booking>>("api/booking") ?? new();

        // Henter alle projekter fra API'et
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
    }

    // Skifter aktiv sektion og nulstiller formular-state
    private void SkiftSektion(string sektion)
    {
        aktivSektion = sektion;
        LukFormular();
    }

    // =====================
    // PROJEKTER METODER
    // =====================

    // Åbner formularen til at oprette et nyt tomt projekt
    private void VisOpretFormular()
    {
        aktivProjekt = new Projekt { BrugerId = adminId };
        erRedigering = false;
        projektStatus = "";
        visFormular = true;
    }

    // Åbner formularen udfyldt med det valgte projekts data
    private void VisRedigerFormular(Projekt p)
    {
        // Kopierer projektet så ændringer ikke vises i listen før man gemmer
        aktivProjekt = new Projekt
        {
            Id = p.Id,
            BrugerId = p.BrugerId,
            Navn = p.Navn,
            Beskrivelse = p.Beskrivelse,
            År = p.År,
            Billeder = p.Billeder.Select(b => new BilledeItem { FileName = b.FileName, Beskrivelse = b.Beskrivelse }).ToList(),
            Oprettelse = p.Oprettelse
        };
        erRedigering = true;
        projektStatus = "";
        visFormular = true;
    }

    // Lukker formularen og vender tilbage til listen
    private void LukFormular()
    {
        visFormular = false;
        projektStatus = "";
    }

    // Uploader valgte billedfiler til serveren og gemmer filnavnene på projektet
    private async Task UploadBilleder(InputFileChangeEventArgs e)
    {
        uploaderBilleder = true;

        foreach (var file in e.GetMultipleFiles())
        {
            var stream = file.OpenReadStream(maxAllowedSize: 10_000_000);
            var (success, fileName) = await FileService.SendFile(file.Name, stream);

            // Opretter et BilledeItem med filnavnet — beskrivelsen kan udfyldes i formularen
            if (success)
                aktivProjekt.Billeder.Add(new BilledeItem { FileName = fileName });
        }

        uploaderBilleder = false;
    }

    // Fjerner et billede fra projektet og sletter det fra databasen
    private async Task FjernBillede(BilledeItem billede)
    {
        aktivProjekt.Billeder.Remove(billede);
        await FileService.DeleteFile(billede.FileName);
    }

    // Gemmer projektet — POST ved opret, PUT ved rediger
    private async Task GemProjekt()
    {
        if (erRedigering)
        {
            // Opdaterer det eksisterende projekt i databasen
            await Http.PutAsJsonAsync($"api/projekt/{aktivProjekt.Id}", aktivProjekt);
            projektStatus = "Projektet er opdateret.";
        }
        else
        {
            // Opretter et nyt projekt i databasen
            await Http.PostAsJsonAsync("api/projekt", aktivProjekt);
            projektStatus = "Projektet er oprettet.";
        }

        // Opdaterer listen så det nye/ændrede projekt vises med det samme
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
        LukFormular();
    }

    // Sletter et projekt og dets tilhørende billeder fra databasen
    private async Task SletProjekt(int id)
    {
        var projekt = projekter?.FirstOrDefault(p => p.Id == id);

        if (projekt != null)
        {
            // Sletter hvert billede fra MongoDB inden projektet slettes
            foreach (var billede in projekt.Billeder)
            {
                await FileService.DeleteFile(billede.FileName);
            }
        }

        await Http.DeleteAsync($"api/projekt/{id}");

        // Opdaterer listen efter sletning
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
    }

    // Logger brugeren ud og sender dem til forsiden
    private async Task LogUd()
    {
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userName");
        await LocalStorage.RemoveItemAsync("userRole");
        Navigation.NavigateTo("/");
    }
}
