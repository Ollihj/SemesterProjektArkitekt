@page "/admin"
@using Core.Models
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Admin Dashboard</PageTitle>

<!-- =====================
     DASHBOARD LAYOUT
     Sidebar til venstre med sektionsknapper, hovedindhold til højre
     ===================== -->
<div class="admin-layout">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="admin-logo">JOHAN BERTHELSEN, ARKITEKT MAA</div>
        <p class="admin-velkommen">Velkommen, @brugerNavn</p>

        <!-- Sektionsknapper — klik skifter den aktive sektion uden at genindlæse siden -->
        <nav class="admin-nav">
            <button class="admin-nav-btn @(aktivSektion == "henvendelser" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("henvendelser")'>
                Henvendelser
            </button>
            <button class="admin-nav-btn @(aktivSektion == "medarbejdere" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("medarbejdere")'>
                Medarbejdere
            </button>
            <button class="admin-nav-btn @(aktivSektion == "projekter" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("projekter")'>
                Projekter
            </button>
            <button class="admin-nav-btn @(aktivSektion == "kalender" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("kalender")'>
                Kalender
            </button>
        </nav>

        <!-- Log ud og tilbage til forside i bunden af sidebaren -->
        <div class="admin-sidebar-footer">
            <button class="admin-nav-btn" @onclick='() => Navigation.NavigateTo("/")'>← Forside</button>
            <button class="admin-nav-btn admin-log-ud" @onclick="LogUd">Log ud</button>
        </div>
    </aside>

    <!-- HOVEDINDHOLD -->
    <main class="admin-main">

        <!-- =====================
             HENVENDELSER SEKTION
             Viser alle indkomne bookinger fra kunder i en tabel
             ===================== -->
        @if (aktivSektion == "henvendelser")
        {
            <h2 class="admin-sektion-titel">Henvendelser</h2>

            @if (henvendelser == null)
            {
                <!-- Vises mens henvendelser hentes fra serveren -->
                <p>Henter henvendelser...</p>
            }
            else if (henvendelser.Count == 0)
            {
                <p class="admin-tom">Ingen henvendelser endnu.</p>
            }
            else
            {
                <table class="admin-tabel">
                    <thead>
                        <tr>
                            <th>NAVN</th>
                            <th>EMAIL</th>
                            <th>TELEFON</th>
                            <th>ØNSKET DATO</th>
                            <th>BESKRIVELSE</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in henvendelser)
                        {
                            <tr>
                                <td>@h.Kundenavn</td>
                                <td>@h.Kundemail</td>
                                <td>@h.KundeTlf</td>
                                <td>@h.OensketDato.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@h.Beskrivelse</td>
                                <td>
                                    <div class="admin-henvendelse-knapper">
                                        <button class="admin-knap" @onclick="() => AccepterHenvendelse(h)">Accepter</button>
                                        <button class="admin-knap-fare" @onclick="() => AfvisHenvendelse(h.Id)">Afvis</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- =====================
             MEDARBEJDERE SEKTION
             Liste over medarbejdere med mulighed for at oprette og slette
             ===================== -->
        @if (aktivSektion == "medarbejdere")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Medarbejdere</h2>
                @if (!visOpretMedarbejder)
                {
                    <button class="admin-knap" @onclick="VisOpretMedarbejderFormular">+ Ny medarbejder</button>
                }
            </div>

            <!-- OPRET FORMULAR -->
            @if (visOpretMedarbejder)
            {
                <div class="admin-formular">
                    <h3 class="admin-formular-titel">@(erRedigeringMedarbejder ? "Rediger medarbejder" : "Ny medarbejder")</h3>

                    <div class="admin-felt">
                        <label>NAVN</label>
                        <input type="text" @bind="nyMedarbejder.Navn" placeholder="Fulde navn" />
                    </div>

                    <div class="admin-felt">
                        <label>EMAIL</label>
                        <input type="email" @bind="nyMedarbejder.Email" placeholder="email@eksempel.dk" />
                    </div>

                    <div class="admin-felt">
                        <label>KODEORD</label>
                        <input type="password" @bind="nyMedarbejder.Password" placeholder="Kodeord" />
                    </div>

                    <div class="admin-felt">
                        <label>TELEFON</label>
                        <input type="text" @bind="nyMedarbejder.Telefon" placeholder="+45" />
                    </div>

                    @if (!string.IsNullOrEmpty(medarbejderFejl))
                    {
                        <p class="admin-fejl">@medarbejderFejl</p>
                    }



                    <div class="admin-formular-knapper">
                        <button class="admin-knap" @onclick="GemMedarbejder">@(erRedigeringMedarbejder ? "Gem ændringer" : "Opret medarbejder")</button>
                        <button class="admin-knap-sek" @onclick="LukMedarbejderFormular">Annuller</button>
                    </div>
                </div>
            }

            <!-- LISTE -->
            @if (medarbejdere.Count == 0)
            {
                <p class="admin-tom">Ingen medarbejdere endnu.</p>
            }
            else
            {
                <table class="admin-tabel">
                    <thead>
                        <tr>
                            <th>NAVN</th>
                            <th>EMAIL</th>
                            <th>TELEFON</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in medarbejdere)
                        {
                            <tr>
                                <td>@m.Navn</td>
                                <td>@m.Email</td>
                                <td>@(m.Telefon ?? "—")</td>
                                <td>
                                    <div class="admin-henvendelse-knapper">
                                        <button class="admin-knap-sek" @onclick="() => VisRedigerMedarbejderFormular(m)">Rediger</button>
                                        <button class="admin-knap-fare" @onclick="() => SletMedarbejder(m.Id)">Slet</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- =====================
             PROJEKTER SEKTION
             Liste over projekter med mulighed for at oprette og redigere
             ===================== -->
        @if (aktivSektion == "projekter")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Projekter</h2>

                @if (!visFormular)
                {
                    <!-- Knap til at åbne opret-formularen -->
                    <button class="admin-knap" @onclick="VisOpretFormular">+ Opret nyt projekt</button>
                }
            </div>

            @if (!visFormular)
            {
                <!-- LISTE OVER EKSISTERENDE PROJEKTER -->
                @if (projekter == null)
                {
                    <p>Henter projekter...</p>
                }
                else if (projekter.Count == 0)
                {
                    <p class="admin-tom">Ingen projekter endnu.</p>
                }
                else
                {
                    <div class="admin-projekt-grid">
                        @foreach (var p in projekter)
                        {
                            <div class="admin-projekt-kort">
                                <!-- Viser det første billede som thumbnail, eller en grå flade hvis ingen billeder -->
                                <div class="admin-projekt-billede">
                                    @if (p.Billeder.Any())
                                    {
                                        <img src="@FileService.GetImageUrl(p.Billeder.First().FileName)" alt="@p.Navn" />
                                    }
                                    else
                                    {
                                        <span>Intet billede</span>
                                    }
                                </div>
                                <div class="admin-projekt-info">
                                    <p class="admin-projekt-navn">@p.Navn</p>
                                    <p class="admin-projekt-aar">@p.År</p>
                                    <div class="admin-projekt-knapper">
                                        <!-- Rediger-knap udfylder formularen med projektets data -->
                                        <button class="admin-knap-sek" @onclick="() => VisRedigerFormular(p)">Rediger</button>
                                        <button class="admin-knap-fare" @onclick="() => SletProjekt(p.Id)">Slet</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- =====================
                     OPRET / REDIGER FORMULAR
                     Samme formular bruges til både opret og rediger
                     erRedigering styrer om der sendes POST eller PUT
                     ===================== -->
                <div class="admin-formular">
                    <h3 class="admin-formular-titel">@(erRedigering ? "Rediger projekt" : "Nyt projekt")</h3>

                    <!-- Navn -->
                    <div class="admin-felt">
                        <label>NAVN</label>
                        <input type="text" @bind="aktivProjekt.Navn" placeholder="Projektnavn" />
                    </div>

                    <!-- Beskrivelse -->
                    <div class="admin-felt">
                        <label>BESKRIVELSE</label>
                        <textarea @bind="aktivProjekt.Beskrivelse" rows="4" placeholder="Beskriv projektet..."></textarea>
                    </div>

                    <!-- År -->
                    <div class="admin-felt">
                        <label>ÅR</label>
                        <input type="number" @bind="aktivProjekt.År" placeholder="2024" />
                    </div>

                    <!-- Billeder med beskrivelse — viser alle uploadede billeder med et beskrivelsesfelt under hvert -->
                    @if (aktivProjekt.Billeder.Any())
                    {
                        <div class="admin-felt">
                            <label>BILLEDER</label>
                            @foreach (var billede in aktivProjekt.Billeder.ToList())
                            {
                                <div class="admin-billede-item">
                                    <div class="admin-billede-thumb">
                                        <img src="@FileService.GetImageUrl(billede.FileName)" alt="billede" />
                                        <!-- Slet-knap fjerner billedet fra projektet og databasen -->
                                        <button class="admin-billede-slet" @onclick="() => FjernBillede(billede)">×</button>
                                    </div>
                                    <!-- Beskrivelsesfelt til hvert enkelt billede -->
                                    <input type="text"
                                           class="admin-billede-beskrivelse"
                                           @bind="billede.Beskrivelse"
                                           placeholder="Beskriv dette billede..." />
                                </div>
                            }
                        </div>
                    }

                    <!-- Upload nye billeder — hvert nyt billede tilføjes til listen ovenfor -->
                    <div class="admin-felt">
                        <label>TILFØJ BILLEDER</label>
                        <InputFile OnChange="UploadBilleder" multiple accept="image/*" />
                        @if (uploaderBilleder)
                        {
                            <p class="admin-upload-status">Uploader billeder...</p>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(projektFejl))
                    {
                        <p class="admin-fejl">@projektFejl</p>
                    }

                    @if (!string.IsNullOrEmpty(projektStatus))
                    {
                        <p class="admin-status">@projektStatus</p>
                    }

                    <div class="admin-formular-knapper">
                        <button class="admin-knap" @onclick="GemProjekt">Gem projekt</button>
                        <!-- Annuller lukker formularen og viser listen igen -->
                        <button class="admin-knap-sek" @onclick="LukFormular">Annuller</button>
                    </div>
                </div>
            }
        }

        <!-- =====================
             KALENDER SEKTION
             Månedsoverblik med indikator på dage der har aftaler
             Klik på dag viser aftalerne for den dag og giver mulighed for at oprette ny
             ===================== -->
        @if (aktivSektion == "kalender")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Kalender</h2>
            </div>

            <!-- MÅNEDS NAVIGATION -->
            <div class="kalender-nav">
                <button class="kalender-nav-knap" @onclick="ForrigeMåned">←</button>
                <span class="kalender-nav-titel">
                    @(new DateTime(kalenderÅr, kalenderMåned, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("da-DK")))
                </span>
                <button class="kalender-nav-knap" @onclick="NæsteMåned">→</button>
            </div>

            <!-- KALENDER GRID
                 7 kolonner — man til søn
                 Tomme celler tilføjes før den 1. dag i måneden -->
            <div class="kalender-grid">

                <!-- Ugedags-headers -->
                <div class="kalender-dag-header">Man</div>
                <div class="kalender-dag-header">Tir</div>
                <div class="kalender-dag-header">Ons</div>
                <div class="kalender-dag-header">Tor</div>
                <div class="kalender-dag-header">Fre</div>
                <div class="kalender-dag-header">Lør</div>
                <div class="kalender-dag-header">Søn</div>

                @{
                    // Beregner hvilken ugedag den 1. i måneden falder på (mandag = 0)
                    var førsteDag = new DateTime(kalenderÅr, kalenderMåned, 1);
                    var offset = ((int)førsteDag.DayOfWeek - 1 + 7) % 7;
                    var dageIMåned = DateTime.DaysInMonth(kalenderÅr, kalenderMåned);
                }

                <!-- Tomme celler inden månedens første dag -->
                @for (int i = 0; i < offset; i++)
                {
                    <div class="kalender-celle tom"></div>
                }

                <!-- En celle per dag i måneden -->
                @for (int d = 1; d <= dageIMåned; d++)
                {
                    var dato = new DateTime(kalenderÅr, kalenderMåned, d);
                    var harAftaler = KalenderHarAftaler(dato);
                    var erValgt = valgtDag?.Date == dato.Date;
                    var erIdag = dato.Date == DateTime.Today;
                    var erBlokeret = ErDagBlokeret(dato);

                    <div class="kalender-celle @(erValgt ? "valgt" : "") @(erIdag ? "idag" : "") @(erBlokeret ? "blokeret" : "")"
                         @onclick="() => VælgDag(dato)">
                        <span class="kalender-dag-nr">@d</span>
                        @if (harAftaler)
                        {
                            <!-- Lille prik der indikerer at der er aftaler denne dag -->
                            <div class="kalender-indikator"></div>
                        }
                    </div>
                }
            </div>

            <!-- VALGT DAG PANEL
                 Vises når man klikker på en dag — lister aftalerne og giver mulighed for at oprette ny -->
            @if (valgtDag != null)
            {
                var dagAftaler = KalenderAftalerForDag(valgtDag.Value);

                <div class="kalender-dag-panel">
                    <div class="kalender-dag-panel-header">
                        <h3>@(valgtDag.Value.ToString("dddd d. MMMM yyyy", new System.Globalization.CultureInfo("da-DK")))</h3>
                        <div style="display:flex;gap:8px;">
                            @if (ErDagBlokeret(valgtDag.Value))
                            {
                                <button class="admin-knap-sek" @onclick="() => FjernBlokering(valgtDag.Value)">Fjern blokering</button>
                            }
                            else
                            {
                                <button class="admin-knap-fare" @onclick="() => BlokerDag(valgtDag.Value)">Bloker dato</button>
                            }
                            <button class="admin-knap" @onclick="VisOpretAftaleForm">+ Ny aftale</button>
                        </div>
                    </div>

                    @if (dagAftaler.Count == 0)
                    {
                        <p class="admin-tom">Ingen aftaler denne dag.</p>
                    }
                    else
                    {
                        <!-- Aftalerne for den valgte dag sorteret efter starttidspunkt -->
                        @foreach (var a in dagAftaler.OrderBy(a => a.StartTid))
                        {
                            <div class="kalender-aftale-item">
                                <div class="kalender-aftale-tid">
                                    @a.StartTid.ToString("HH:mm") — @a.SlutTid.ToString("HH:mm")
                                </div>
                                <div class="kalender-aftale-info">
                                    <p class="kalender-aftale-titel">@a.Titel</p>
                                    @if (!string.IsNullOrEmpty(a.Beskrivelse))
                                    {
                                        <p class="kalender-aftale-beskrivelse">@a.Beskrivelse</p>
                                    }
                                    @if (a.Type == "booking")
                                    {
                                        @if (!string.IsNullOrEmpty(a.Kundemail))
                                        {
                                            <p class="kalender-aftale-beskrivelse">✉ @a.Kundemail</p>
                                        }
                                        @if (!string.IsNullOrEmpty(a.KundeTlf))
                                        {
                                            <p class="kalender-aftale-beskrivelse">📞 @a.KundeTlf</p>
                                        }
                                    }
                                </div>
                                <button class="admin-knap-fare" @onclick="() => SletAftale(a.Id)">Slet</button>
                            </div>
                        }
                    }

                    <!-- OPRET AFTALE FORMULAR — vises når man trykker "+ Ny aftale" -->
                    @if (visOpretAftale)
                    {
                        <div class="admin-formular kalender-formular">
                            <h3 class="admin-formular-titel">Ny aftale</h3>

                            <div class="admin-felt">
                                <label>TITEL</label>
                                <input type="text" @bind="nyAftale.Titel" placeholder="Aftaletitel" />
                            </div>

                            <!-- Start og slut vises side om side -->
                            <div class="kalender-tider">
                                <div class="admin-felt">
                                    <label>START</label>
                                    <input type="time" @bind="nyAftaleStartTid" />
                                </div>
                                <div class="admin-felt">
                                    <label>SLUT</label>
                                    <input type="time" @bind="nyAftaleSlutTid" />
                                </div>
                            </div>

                            <div class="admin-felt">
                                <label>BESKRIVELSE</label>
                                <textarea @bind="nyAftale.Beskrivelse" rows="3"
                                          placeholder="Beskriv aftalen..."></textarea>
                            </div>

                            <div class="admin-formular-knapper">
                                <button class="admin-knap" @onclick="GemAftale">Gem aftale</button>
                                <button class="admin-knap-sek" @onclick='() => visOpretAftale = false'>Annuller</button>
                            </div>
                        </div>
                    }
                </div>
            }
        }

    </main>
</div>
