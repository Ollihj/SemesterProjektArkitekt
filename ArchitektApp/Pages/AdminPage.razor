@page "/admin"
@using Core.Models
@using Blazored.LocalStorage
@using ArchitektApp.Service
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject HttpClient Http
@inject FileService FileService

<PageTitle>Admin Dashboard</PageTitle>

<!-- =====================
     DASHBOARD LAYOUT
     Sidebar til venstre med sektionsknapper, hovedindhold til højre
     ===================== -->
<div class="admin-layout">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="admin-logo">JOHAN BERTHELSEN, ARKITEKT MAA</div>
        <p class="admin-velkommen">Velkommen, @brugerNavn</p>

        <!-- Sektionsknapper — klik skifter den aktive sektion uden at genindlæse siden -->
        <nav class="admin-nav">
            <button class="admin-nav-btn @(aktivSektion == "henvendelser" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("henvendelser")'>
                Henvendelser
            </button>
            <button class="admin-nav-btn @(aktivSektion == "medarbejdere" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("medarbejdere")'>
                Medarbejdere
            </button>
            <button class="admin-nav-btn @(aktivSektion == "projekter" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("projekter")'>
                Projekter
            </button>
            <button class="admin-nav-btn @(aktivSektion == "kalender" ? "aktiv" : "")"
                    @onclick='() => SkiftSektion("kalender")'>
                Kalender
            </button>
        </nav>

        <!-- Log ud og tilbage til forside i bunden af sidebaren -->
        <div class="admin-sidebar-footer">
            <button class="admin-nav-btn" @onclick='() => Navigation.NavigateTo("/")'>← Forside</button>
            <button class="admin-nav-btn admin-log-ud" @onclick="LogUd">Log ud</button>
        </div>
    </aside>

    <!-- HOVEDINDHOLD -->
    <main class="admin-main">

        <!-- =====================
             HENVENDELSER SEKTION
             Viser alle indkomne bookinger fra kunder i en tabel
             ===================== -->
        @if (aktivSektion == "henvendelser")
        {
            <h2 class="admin-sektion-titel">Henvendelser</h2>

            @if (henvendelser == null)
            {
                <!-- Vises mens henvendelser hentes fra serveren -->
                <p>Henter henvendelser...</p>
            }
            else if (henvendelser.Count == 0)
            {
                <p class="admin-tom">Ingen henvendelser endnu.</p>
            }
            else
            {
                <table class="admin-tabel">
                    <thead>
                        <tr>
                            <th>NAVN</th>
                            <th>EMAIL</th>
                            <th>TELEFON</th>
                            <th>ØNSKET DATO</th>
                            <th>BESKRIVELSE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in henvendelser)
                        {
                            <tr>
                                <td>@h.Kundenavn</td>
                                <td>@h.Kundemail</td>
                                <td>@h.KundeTlf</td>
                                <!-- Formaterer datoen til dansk format dag/måned/år og klokkeslæt -->
                                <td>@h.OensketDato.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@h.Beskrivelse</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- =====================
             MEDARBEJDERE SEKTION (ikke implementeret endnu)
             ===================== -->
        @if (aktivSektion == "medarbejdere")
        {
            <h2 class="admin-sektion-titel">Medarbejdere</h2>
            <p class="admin-tom">Kommer snart.</p>
        }

        <!-- =====================
             PROJEKTER SEKTION
             Liste over projekter med mulighed for at oprette og redigere
             ===================== -->
        @if (aktivSektion == "projekter")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Projekter</h2>

                @if (!visFormular)
                {
                    <!-- Knap til at åbne opret-formularen -->
                    <button class="admin-knap" @onclick="VisOpretFormular">+ Opret nyt projekt</button>
                }
            </div>

            @if (!visFormular)
            {
                <!-- LISTE OVER EKSISTERENDE PROJEKTER -->
                @if (projekter == null)
                {
                    <p>Henter projekter...</p>
                }
                else if (projekter.Count == 0)
                {
                    <p class="admin-tom">Ingen projekter endnu.</p>
                }
                else
                {
                    <div class="admin-projekt-grid">
                        @foreach (var p in projekter)
                        {
                            <div class="admin-projekt-kort">
                                <!-- Viser det første billede som thumbnail, eller en grå flade hvis ingen billeder -->
                                <div class="admin-projekt-billede">
                                    @if (p.Billeder.Any())
                                    {
                                        <img src="@FileService.GetImageUrl(p.Billeder.First().FileName)" alt="@p.Navn" />
                                    }
                                    else
                                    {
                                        <span>Intet billede</span>
                                    }
                                </div>
                                <div class="admin-projekt-info">
                                    <p class="admin-projekt-navn">@p.Navn</p>
                                    <p class="admin-projekt-aar">@p.År</p>
                                    <div class="admin-projekt-knapper">
                                        <!-- Rediger-knap udfylder formularen med projektets data -->
                                        <button class="admin-knap-sek" @onclick="() => VisRedigerFormular(p)">Rediger</button>
                                        <button class="admin-knap-fare" @onclick="() => SletProjekt(p.Id)">Slet</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- =====================
                     OPRET / REDIGER FORMULAR
                     Samme formular bruges til både opret og rediger
                     erRedigering styrer om der sendes POST eller PUT
                     ===================== -->
                <div class="admin-formular">
                    <h3 class="admin-formular-titel">@(erRedigering ? "Rediger projekt" : "Nyt projekt")</h3>

                    <!-- Navn -->
                    <div class="admin-felt">
                        <label>NAVN</label>
                        <input type="text" @bind="aktivProjekt.Navn" placeholder="Projektnavn" />
                    </div>

                    <!-- Beskrivelse -->
                    <div class="admin-felt">
                        <label>BESKRIVELSE</label>
                        <textarea @bind="aktivProjekt.Beskrivelse" rows="4" placeholder="Beskriv projektet..."></textarea>
                    </div>

                    <!-- År -->
                    <div class="admin-felt">
                        <label>ÅR</label>
                        <input type="number" @bind="aktivProjekt.År" placeholder="2024" />
                    </div>

                    <!-- Billeder med beskrivelse — viser alle uploadede billeder med et beskrivelsesfelt under hvert -->
                    @if (aktivProjekt.Billeder.Any())
                    {
                        <div class="admin-felt">
                            <label>BILLEDER</label>
                            @foreach (var billede in aktivProjekt.Billeder.ToList())
                            {
                                <div class="admin-billede-item">
                                    <div class="admin-billede-thumb">
                                        <img src="@FileService.GetImageUrl(billede.FileName)" alt="billede" />
                                        <!-- Slet-knap fjerner billedet fra projektet og databasen -->
                                        <button class="admin-billede-slet" @onclick="() => FjernBillede(billede)">×</button>
                                    </div>
                                    <!-- Beskrivelsesfelt til hvert enkelt billede -->
                                    <input type="text"
                                           class="admin-billede-beskrivelse"
                                           @bind="billede.Beskrivelse"
                                           placeholder="Beskriv dette billede..." />
                                </div>
                            }
                        </div>
                    }

                    <!-- Upload nye billeder — hvert nyt billede tilføjes til listen ovenfor -->
                    <div class="admin-felt">
                        <label>TILFØJ BILLEDER</label>
                        <InputFile OnChange="UploadBilleder" multiple accept="image/*" />
                        @if (uploaderBilleder)
                        {
                            <p class="admin-upload-status">Uploader billeder...</p>
                        }
                    </div>

                    <!-- Statusbesked der vises efter gem forsøg -->
                    @if (!string.IsNullOrEmpty(projektStatus))
                    {
                        <p class="admin-status">@projektStatus</p>
                    }

                    <div class="admin-formular-knapper">
                        <button class="admin-knap" @onclick="GemProjekt">Gem projekt</button>
                        <!-- Annuller lukker formularen og viser listen igen -->
                        <button class="admin-knap-sek" @onclick="LukFormular">Annuller</button>
                    </div>
                </div>
            }
        }

        <!-- =====================
             KALENDER SEKTION
             Månedsoverblik med indikator på dage der har aftaler
             Klik på dag viser aftalerne for den dag og giver mulighed for at oprette ny
             ===================== -->
        @if (aktivSektion == "kalender")
        {
            <div class="admin-sektion-header">
                <h2 class="admin-sektion-titel">Kalender</h2>
            </div>

            <!-- MÅNEDS NAVIGATION -->
            <div class="kalender-nav">
                <button class="kalender-nav-knap" @onclick="ForrigeMåned">←</button>
                <span class="kalender-nav-titel">
                    @(new DateTime(kalenderÅr, kalenderMåned, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("da-DK")))
                </span>
                <button class="kalender-nav-knap" @onclick="NæsteMåned">→</button>
            </div>

            <!-- KALENDER GRID
                 7 kolonner — man til søn
                 Tomme celler tilføjes før den 1. dag i måneden -->
            <div class="kalender-grid">

                <!-- Ugedags-headers -->
                <div class="kalender-dag-header">Man</div>
                <div class="kalender-dag-header">Tir</div>
                <div class="kalender-dag-header">Ons</div>
                <div class="kalender-dag-header">Tor</div>
                <div class="kalender-dag-header">Fre</div>
                <div class="kalender-dag-header">Lør</div>
                <div class="kalender-dag-header">Søn</div>

                @{
                    // Beregner hvilken ugedag den 1. i måneden falder på (mandag = 0)
                    var førsteDag = new DateTime(kalenderÅr, kalenderMåned, 1);
                    var offset = ((int)førsteDag.DayOfWeek - 1 + 7) % 7;
                    var dageIMåned = DateTime.DaysInMonth(kalenderÅr, kalenderMåned);
                }

                <!-- Tomme celler inden månedens første dag -->
                @for (int i = 0; i < offset; i++)
                {
                    <div class="kalender-celle tom"></div>
                }

                <!-- En celle per dag i måneden -->
                @for (int d = 1; d <= dageIMåned; d++)
                {
                    var dato = new DateTime(kalenderÅr, kalenderMåned, d);
                    var harAftaler = KalenderHarAftaler(dato);
                    var erValgt = valgtDag?.Date == dato.Date;
                    var erIdag = dato.Date == DateTime.Today;
                    var erBlokeret = ErDagBlokeret(dato);

                    <div class="kalender-celle @(erValgt ? "valgt" : "") @(erIdag ? "idag" : "") @(erBlokeret ? "blokeret" : "")"
                         @onclick="() => VælgDag(dato)">
                        <span class="kalender-dag-nr">@d</span>
                        @if (harAftaler)
                        {
                            <!-- Lille prik der indikerer at der er aftaler denne dag -->
                            <div class="kalender-indikator"></div>
                        }
                    </div>
                }
            </div>

            <!-- VALGT DAG PANEL
                 Vises når man klikker på en dag — lister aftalerne og giver mulighed for at oprette ny -->
            @if (valgtDag != null)
            {
                var dagAftaler = KalenderAftalerForDag(valgtDag.Value);

                <div class="kalender-dag-panel">
                    <div class="kalender-dag-panel-header">
                        <h3>@(valgtDag.Value.ToString("dddd d. MMMM yyyy", new System.Globalization.CultureInfo("da-DK")))</h3>
                        <div style="display:flex;gap:8px;">
                            @if (ErDagBlokeret(valgtDag.Value))
                            {
                                <button class="admin-knap-sek" @onclick="() => FjernBlokering(valgtDag.Value)">Fjern blokering</button>
                            }
                            else
                            {
                                <button class="admin-knap-fare" @onclick="() => BlokerDag(valgtDag.Value)">Bloker dato</button>
                            }
                            <button class="admin-knap" @onclick="VisOpretAftaleForm">+ Ny aftale</button>
                        </div>
                    </div>

                    @if (dagAftaler.Count == 0)
                    {
                        <p class="admin-tom">Ingen aftaler denne dag.</p>
                    }
                    else
                    {
                        <!-- Aftalerne for den valgte dag sorteret efter starttidspunkt -->
                        @foreach (var a in dagAftaler.OrderBy(a => a.StartTid))
                        {
                            <div class="kalender-aftale-item">
                                <div class="kalender-aftale-tid">
                                    @a.StartTid.ToString("HH:mm") — @a.SlutTid.ToString("HH:mm")
                                </div>
                                <div class="kalender-aftale-info">
                                    <p class="kalender-aftale-titel">@a.Titel</p>
                                    @if (!string.IsNullOrEmpty(a.Beskrivelse))
                                    {
                                        <p class="kalender-aftale-beskrivelse">@a.Beskrivelse</p>
                                    }
                                </div>
                                <button class="admin-knap-fare" @onclick="() => SletAftale(a.Id)">Slet</button>
                            </div>
                        }
                    }

                    <!-- OPRET AFTALE FORMULAR — vises når man trykker "+ Ny aftale" -->
                    @if (visOpretAftale)
                    {
                        <div class="admin-formular kalender-formular">
                            <h3 class="admin-formular-titel">Ny aftale</h3>

                            <div class="admin-felt">
                                <label>TITEL</label>
                                <input type="text" @bind="nyAftale.Titel" placeholder="Aftaletitel" />
                            </div>

                            <!-- Start og slut vises side om side -->
                            <div class="kalender-tider">
                                <div class="admin-felt">
                                    <label>START</label>
                                    <input type="time" @bind="nyAftaleStartTid" />
                                </div>
                                <div class="admin-felt">
                                    <label>SLUT</label>
                                    <input type="time" @bind="nyAftaleSlutTid" />
                                </div>
                            </div>

                            <div class="admin-felt">
                                <label>BESKRIVELSE</label>
                                <textarea @bind="nyAftale.Beskrivelse" rows="3"
                                          placeholder="Beskriv aftalen..."></textarea>
                            </div>

                            <div class="admin-formular-knapper">
                                <button class="admin-knap" @onclick="GemAftale">Gem aftale</button>
                                <button class="admin-knap-sek" @onclick='() => visOpretAftale = false'>Annuller</button>
                            </div>
                        </div>
                    }
                </div>
            }
        }

    </main>
</div>

@code {
    // Styrer hvilken sektion der vises — starter med henvendelser
    private string aktivSektion = "henvendelser";

    private string brugerNavn = "";
    private int adminId = 0;

    // Core.Models.Booking bruges eksplicit fordi Booking.razor-komponenten ellers skaber navnekollision
    private List<Core.Models.Booking>? henvendelser;

    // =====================
    // PROJEKTER STATE
    // =====================

    private List<Projekt>? projekter;

    // Styrer om listen eller formularen vises i projekter-sektionen
    private bool visFormular = false;

    // True når man redigerer et eksisterende projekt, false når man opretter nyt
    private bool erRedigering = false;

    // Det projekt der aktuelt oprettes eller redigeres
    private Projekt aktivProjekt = new();

    private bool uploaderBilleder = false;
    private string projektStatus = "";

    // =====================
    // KALENDER STATE
    // =====================

    // Den måned og det år der vises i kalenderen — starter på den aktuelle måned
    private int kalenderMåned = DateTime.Now.Month;
    private int kalenderÅr = DateTime.Now.Year;

    // Liste over adminens egne aftaler
    private List<Aftale> aftaler = new();

    // Liste over blokerede datoer
    private List<Core.Models.Blokeret> blokereteDatoer = new();

    // Den dag der er klikket på — null hvis ingen dag er valgt
    private DateTime? valgtDag = null;

    // Styrer om opret-formularen vises under den valgte dag
    private bool visOpretAftale = false;

    // Den nye aftale der er ved at blive oprettet
    private Aftale nyAftale = new();

    // Separate tidsvariabler fordi Blazor binder type="time" til TimeOnly
    private TimeOnly nyAftaleStartTid = new TimeOnly(9, 0);
    private TimeOnly nyAftaleSlutTid = new TimeOnly(10, 0);

    // Kører automatisk når siden indlæses
    protected override async Task OnInitializedAsync()
    {
        // Henter brugeroplysninger fra LocalStorage
        var userRole = await LocalStorage.GetItemAsync<string>("userRole");
        brugerNavn = await LocalStorage.GetItemAsync<string>("userName") ?? "";
        adminId = await LocalStorage.GetItemAsync<int>("userId");

        // Hvis brugeren ikke er admin sendes de tilbage til forsiden
        if (userRole != "admin")
        {
            Navigation.NavigateTo("/");
            return;
        }

        // Henter alle henvendelser fra API'et
        henvendelser = await Http.GetFromJsonAsync<List<Core.Models.Booking>>("api/booking") ?? new();

        // Henter alle projekter fra API'et
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();

        // Henter adminens egne aftaler baseret på adminId
        aftaler = await Http.GetFromJsonAsync<List<Aftale>>($"api/aftale/bruger/{adminId}") ?? new();

        // Henter alle blokerede datoer
        blokereteDatoer = await Http.GetFromJsonAsync<List<Core.Models.Blokeret>>("api/blokeret") ?? new();
    }

    // Skifter aktiv sektion og nulstiller formular-state
    private void SkiftSektion(string sektion)
    {
        aktivSektion = sektion;
        LukFormular();
    }

    // =====================
    // PROJEKTER METODER
    // =====================

    // Åbner formularen til at oprette et nyt tomt projekt
    private void VisOpretFormular()
    {
        aktivProjekt = new Projekt { BrugerId = adminId };
        erRedigering = false;
        projektStatus = "";
        visFormular = true;
    }

    // Åbner formularen udfyldt med det valgte projekts data
    private void VisRedigerFormular(Projekt p)
    {
        // Kopierer projektet så ændringer ikke vises i listen før man gemmer
        aktivProjekt = new Projekt
        {
            Id = p.Id,
            BrugerId = p.BrugerId,
            Navn = p.Navn,
            Beskrivelse = p.Beskrivelse,
            År = p.År,
            Billeder = p.Billeder.Select(b => new BilledeItem { FileName = b.FileName, Beskrivelse = b.Beskrivelse }).ToList(),
            Oprettelse = p.Oprettelse
        };
        erRedigering = true;
        projektStatus = "";
        visFormular = true;
    }

    // Lukker formularen og vender tilbage til listen
    private void LukFormular()
    {
        visFormular = false;
        projektStatus = "";
    }

    // Uploader valgte billedfiler til serveren og gemmer filnavnene på projektet
    private async Task UploadBilleder(InputFileChangeEventArgs e)
    {
        uploaderBilleder = true;

        foreach (var file in e.GetMultipleFiles())
        {
            var stream = file.OpenReadStream(maxAllowedSize: 10_000_000);
            var (success, fileName) = await FileService.SendFile(file.Name, stream);

            // Opretter et BilledeItem med filnavnet — beskrivelsen kan udfyldes i formularen
            if (success)
                aktivProjekt.Billeder.Add(new BilledeItem { FileName = fileName });
        }

        uploaderBilleder = false;
    }

    // Fjerner et billede fra projektet og sletter det fra databasen
    private async Task FjernBillede(BilledeItem billede)
    {
        aktivProjekt.Billeder.Remove(billede);
        await FileService.DeleteFile(billede.FileName);
    }

    // Gemmer projektet — POST ved opret, PUT ved rediger
    private async Task GemProjekt()
    {
        if (erRedigering)
        {
            // Opdaterer det eksisterende projekt i databasen
            await Http.PutAsJsonAsync($"api/projekt/{aktivProjekt.Id}", aktivProjekt);
            projektStatus = "Projektet er opdateret.";
        }
        else
        {
            // Opretter et nyt projekt i databasen
            await Http.PostAsJsonAsync("api/projekt", aktivProjekt);
            projektStatus = "Projektet er oprettet.";
        }

        // Opdaterer listen så det nye/ændrede projekt vises med det samme
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
        LukFormular();
    }

    // Sletter et projekt og dets tilhørende billeder fra databasen
    private async Task SletProjekt(int id)
    {
        var projekt = projekter?.FirstOrDefault(p => p.Id == id);

        if (projekt != null)
        {
            // Sletter hvert billede fra MongoDB inden projektet slettes
            foreach (var billede in projekt.Billeder)
            {
                await FileService.DeleteFile(billede.FileName);
            }
        }

        await Http.DeleteAsync($"api/projekt/{id}");

        // Opdaterer listen efter sletning
        projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
    }

    // Logger brugeren ud og sender dem til forsiden
    private async Task LogUd()
    {
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userName");
        await LocalStorage.RemoveItemAsync("userRole");
        Navigation.NavigateTo("/");
    }

    // =====================
    // KALENDER METODER
    // =====================

    // Går en måned tilbage — håndterer årsskifte
    private void ForrigeMåned()
    {
        if (kalenderMåned == 1) { kalenderMåned = 12; kalenderÅr--; }
        else kalenderMåned--;
        valgtDag = null;
    }

    // Går en måned frem — håndterer årsskifte
    private void NæsteMåned()
    {
        if (kalenderMåned == 12) { kalenderMåned = 1; kalenderÅr++; }
        else kalenderMåned++;
        valgtDag = null;
    }

    // Returnerer true hvis der er aftaler på den given dato
    private bool KalenderHarAftaler(DateTime dag) =>
        aftaler.Any(a => a.StartTid.Date == dag.Date);

    // Returnerer true hvis datoen er blokeret
    private bool ErDagBlokeret(DateTime dag) =>
        blokereteDatoer.Any(b => b.StartTid.Date == dag.Date);

    // Blokerer en dag ved at oprette en Blokeret-post der dækker hele dagen.
    // DateTimeKind.Utc forhindrer MongoDB i at fortolke datoen som lokal tid og gemme den forkert.
    private async Task BlokerDag(DateTime dag)
    {
        var utcDato = DateTime.SpecifyKind(dag.Date, DateTimeKind.Utc);
        var blokeret = new Core.Models.Blokeret
        {
            BrugerId = adminId,
            StartTid = utcDato,
            SlutTid = utcDato.AddDays(1).AddSeconds(-1),
            Type = "dag"
        };

        // Tilføj til listen med det samme så UI opdateres øjeblikkeligt
        blokereteDatoer.Add(blokeret);

        await Http.PostAsJsonAsync("api/blokeret", blokeret);
        blokereteDatoer = await Http.GetFromJsonAsync<List<Core.Models.Blokeret>>("api/blokeret") ?? new();
    }

    // Fjerner blokeringen fra en dag
    private async Task FjernBlokering(DateTime dag)
    {
        var blokeret = blokereteDatoer.FirstOrDefault(b => b.StartTid.Date == dag.Date);
        if (blokeret != null)
        {
            // Fjern fra listen med det samme så UI opdateres øjeblikkeligt
            blokereteDatoer.Remove(blokeret);

            await Http.DeleteAsync($"api/blokeret/{blokeret.Id}");
            blokereteDatoer = await Http.GetFromJsonAsync<List<Core.Models.Blokeret>>("api/blokeret") ?? new();
        }
    }

    // Returnerer alle aftaler for en given dato
    private List<Aftale> KalenderAftalerForDag(DateTime dag) =>
        aftaler.Where(a => a.StartTid.Date == dag.Date).ToList();

    // Sætter den valgte dag og nulstiller opret-formularen
    private void VælgDag(DateTime dag)
    {
        valgtDag = dag;
        visOpretAftale = false;
        nyAftale = new Aftale { BrugerId = adminId };
        nyAftaleStartTid = new TimeOnly(9, 0);
        nyAftaleSlutTid = new TimeOnly(10, 0);
    }

    // Åbner opret-formularen for den valgte dag
    private void VisOpretAftaleForm()
    {
        visOpretAftale = true;
        nyAftale = new Aftale { BrugerId = adminId };
    }

    // Gemmer en ny aftale og opdaterer listen
    private async Task GemAftale()
    {
        // Kombinerer den valgte dato med de valgte tidspunkter
        nyAftale.StartTid = valgtDag!.Value.Date + nyAftaleStartTid.ToTimeSpan();
        nyAftale.SlutTid = valgtDag!.Value.Date + nyAftaleSlutTid.ToTimeSpan();
        nyAftale.Oprettelse = DateTime.Now;

        await Http.PostAsJsonAsync("api/aftale", nyAftale);

        // Opdaterer listen så den nye aftale vises med det samme
        aftaler = await Http.GetFromJsonAsync<List<Aftale>>($"api/aftale/bruger/{adminId}") ?? new();
        visOpretAftale = false;
        nyAftale = new Aftale { BrugerId = adminId };
    }

    // Sletter en aftale og opdaterer listen
    private async Task SletAftale(int id)
    {
        await Http.DeleteAsync($"api/aftale/{id}");
        aftaler = await Http.GetFromJsonAsync<List<Aftale>>($"api/aftale/bruger/{adminId}") ?? new();
    }
}
