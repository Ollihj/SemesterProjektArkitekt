@page "/LoginPage"
<h3>LoginPage</h3>
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@using Blazored.LocalStorage

<PageTitle>Log ind</PageTitle>

<div class="login-container" style="max-width: 400px; margin: 50px auto; padding: 20px;">
    <h2 style="text-align: center; margin-bottom: 30px;">Log ind</h2>

    <div class="form-group mb-3">
        <label for="username">Brugernavn</label>
        <input id="username" 
               type="text" 
               class="form-control" 
               @bind="username" 
               placeholder="Indtast brugernavn" />
    </div>

    <div class="form-group mb-3">
        <label for="password">Adgangskode</label>
        <input id="password" 
               type="password" 
               class="form-control" 
               @bind="password" 
               placeholder="Indtast adgangskode" />
    </div>

    @if (!string.IsNullOrEmpty(errorText))
    {
        <div class="alert alert-danger" role="alert">
            ⚠️ @errorText
        </div>
    }

    <div style="display: flex; gap: 10px; justify-content: center;">
        <button class="btn btn-primary" @onclick="OnClickLogin" >Log ind</button>
        <a href="/" class="btn btn-secondary">Annuller</a>
    </div>
    
    
    <div style="text-align: center; margin-top: 20px;">
        <p> <a href="/register">Opret bruger her</a></p>
    </div>
</div>
 
    

@code {
    private string username = "";
    private string password = "";
    private string errorText = "";

    private async Task OnClickLogin()
    {
        // 1. Check input
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorText = "Venligst udfyld alle felter";
            return;
        }

        // 2. Try login
        var user = "";

        // 3. If success
        if (user != null)
        {
            await LocalStorage.SetItemAsync("user", user);
            Navigation.NavigateTo("/", true);
            return;
        }

        // 4. If failed
        errorText = "Ugyldigt brugernavn eller adgangskode";
    }
}