@page "/booking"
@using Core.Models
@using Blazored.LocalStorage
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject HttpClient Http

<nav class="home-nav">
    <span class="home-logo">ARKITEKT JOHAN BERTHELSEN, MAA</span>
    <div class="home-nav-links">
        <NavLink href="/" Match="NavLinkMatch.All">FORSIDE</NavLink>
        <NavLink href="/projekter">PROJEKTER</NavLink>
        <NavLink href="/booking">KONTAKT</NavLink>
    </div>
    @if (erLoggetInd)
    {
        <div class="home-nav-right">
            <span>@brugerNavn</span>
            <button @onclick="LogUd">LOG UD</button>
        </div>
    }
    else
    {
        <button @onclick='() => Navigation.NavigateTo("/LoginPage")'>LOG IND</button>
    }
</nav>

<div class="booking-page">
    <!-- Hero/Header Section -->
    <div class="booking-header">
        <div class="container">
            <span class="page-label">KONTAKT</span>
            <h1 class="page-title">
                Lad os tale om<br />dit projekt
            </h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="booking-content">
        <div class="container">
            <div class="row">
                <!-- Left Column - Info -->
                <div class="col-lg-5">
                    <div class="booking-info">
                        <p class="booking-intro">
                            Udfyld formularen, så vender vi tilbage hurtigst muligt for at aftale et uforpligtende møde.
                        </p>

                        <div class="contact-details">
                            <div class="contact-item">
                                <span class="contact-label">EMAIL</span>
                                <a href="mailto:kontakt@arkitektstudio.dk" class="contact-link">
                                    kontakt@arkitektstudio.dk
                                </a>
                            </div>
                            <div class="contact-item">
                                <span class="contact-label">TELEFON</span>
                                <a href="tel:+4512345678" class="contact-link">
                                    +45 12 34 56 78
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Form -->
                <div class="col-lg-6 offset-lg-1">
                    <div class="booking-form-container">
                        <form @onsubmit="SendBooking" @onsubmit:preventDefault>

                            <!-- Navn -->
                            <div class="form-group">
                                <label for="customerName">NAVN</label>
                                <input type="text"
                                       class="form-control"
                                       id="customerName"
                                       placeholder="Dit fulde navn"
                                       @bind="nyBooking.Kundenavn"
                                       required />
                            </div>

                            <!-- Email -->
                            <div class="form-group">
                                <label for="customerEmail">EMAIL</label>
                                <input type="email"
                                       class="form-control"
                                       id="customerEmail"
                                       placeholder="din@email.dk"
                                       @bind="nyBooking.Kundemail"
                                       required />
                            </div>

                            <!-- Telefon -->
                            <div class="form-group">
                                <label for="customerPhone">TELEFON</label>
                                <input type="tel"
                                       class="form-control"
                                       id="customerPhone"
                                       placeholder="+45"
                                       @bind="nyBooking.KundeTlf"
                                       required />
                            </div>

                            <!-- DATO — custom kalender-picker med blokerede dage -->
                            <div class="form-group">
                                <label>DATO</label>

                                <!-- Måneds-navigation -->
                                <div class="booking-kalender-nav">
                                    <button type="button" class="booking-kalender-nav-knap" @onclick="BookingForrigeMåned">←</button>
                                    <span class="booking-kalender-nav-titel">
                                        @(new DateTime(bookingKalenderÅr, bookingKalenderMåned, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("da-DK")))
                                    </span>
                                    <button type="button" class="booking-kalender-nav-knap" @onclick="BookingNæsteMåned">→</button>
                                </div>

                                <!-- Kalender grid -->
                                <div class="booking-kalender-grid">
                                    <div class="booking-kalender-dag-header">Man</div>
                                    <div class="booking-kalender-dag-header">Tir</div>
                                    <div class="booking-kalender-dag-header">Ons</div>
                                    <div class="booking-kalender-dag-header">Tor</div>
                                    <div class="booking-kalender-dag-header">Fre</div>
                                    <div class="booking-kalender-dag-header">Lør</div>
                                    <div class="booking-kalender-dag-header">Søn</div>

                                    @{
                                        var bFørsteDag = new DateTime(bookingKalenderÅr, bookingKalenderMåned, 1);
                                        var bOffset = ((int)bFørsteDag.DayOfWeek - 1 + 7) % 7;
                                        var bDageIMåned = DateTime.DaysInMonth(bookingKalenderÅr, bookingKalenderMåned);
                                    }

                                    @for (int i = 0; i < bOffset; i++)
                                    {
                                        <div class="booking-kalender-celle tom"></div>
                                    }

                                    @for (int d = 1; d <= bDageIMåned; d++)
                                    {
                                        var dato = new DateTime(bookingKalenderÅr, bookingKalenderMåned, d);
                                        var erBlokeret = blokereteDatoer.Any(b => b.StartTid.Date == dato.Date);
                                        var erFortid = dato.Date < DateTime.Today;
                                        var erValgt = valgDato.Date == dato.Date;
                                        var utilgængelig = erBlokeret || erFortid;

                                        <div class="booking-kalender-celle @(utilgængelig ? "utilgaengelig" : "") @(erValgt && !utilgængelig ? "valgt" : "")"
                                             @onclick="() => { if (!utilgængelig) valgDato = dato; }">
                                            @d
                                        </div>
                                    }
                                </div>

                                @if (valgDato != DateTime.MinValue)
                                {
                                    <p class="booking-valgt-dato">Valgt: @valgDato.ToString("d. MMMM yyyy", new System.Globalization.CultureInfo("da-DK"))</p>
                                }
                            </div>

                            <!-- Tidspunkt -->
                            <div class="form-group">
                                <label for="time">TIDSPUNKT</label>
                                <input type="time"
                                       class="form-control"
                                       id="time"
                                       @bind="valgTid"
                                       required />
                            </div>

                            <!-- Beskrivelse -->
                            <div class="form-group">
                                <label for="description">BESKRIVELSE</label>
                                <textarea class="form-control"
                                          id="description"
                                          rows="5"
                                          placeholder="Fortæl os om dit projekt..."
                                          @bind="nyBooking.Beskrivelse"
                                          required></textarea>
                            </div>

                            <!-- Submit knap -->
                            <button type="submit" class="btn-submit">
                                SEND FORESPØRGSEL
                            </button>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    
    private bool erLoggetInd = false;
    private string brugerNavn = "";

    // Blokerede datoer hentet fra API
    private List<Core.Models.Blokeret> blokereteDatoer = new();

    // Kalender-navigation til dato-vælgeren
    private int bookingKalenderMåned = DateTime.Now.Month;
    private int bookingKalenderÅr = DateTime.Now.Year;

    private void BookingForrigeMåned()
    {
        if (bookingKalenderMåned == 1) { bookingKalenderMåned = 12; bookingKalenderÅr--; }
        else bookingKalenderMåned--;
    }

    private void BookingNæsteMåned()
    {
        if (bookingKalenderMåned == 12) { bookingKalenderMåned = 1; bookingKalenderÅr++; }
        else bookingKalenderMåned++;
    }

    protected override async Task OnInitializedAsync()
    {
        var userId = await LocalStorage.GetItemAsync<int?>("userId");
        brugerNavn = await LocalStorage.GetItemAsync<string>("userName") ?? "";
        erLoggetInd = userId != null && userId > 0;

        // Henter blokerede datoer så de kan grå'es ud i kalender-vælgeren
        blokereteDatoer = await Http.GetFromJsonAsync<List<Core.Models.Blokeret>>("api/blokeret") ?? new();
    }

    private async Task LogUd()
    {
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userName");
        await LocalStorage.RemoveItemAsync("userRole");
        erLoggetInd = false;
        brugerNavn = "";
    }
    
    // Opretter et tomt Booking objekt som formularen udfylder
    // Core.Models.Booking bruges her fordi Booking.razor selv hedder "Booking" og skaber navnekollision
    private Core.Models.Booking nyBooking = new Core.Models.Booking();

    // Separate variabler til dato og tidspunkt som sættes sammen inden afsendelse
    private DateTime valgDato = DateTime.Today;
    private TimeOnly valgTid = new TimeOnly(9, 0);

    private async Task SendBooking()
    {
        // Sætter dato og tidspunkt sammen til ét DateTime felt
        nyBooking.OensketDato = valgDato.Date + valgTid.ToTimeSpan();

        // Sender bookingen til API'et som gemmer den i MongoDB
        await Http.PostAsJsonAsync("api/booking", nyBooking);

        // Sender brugeren tilbage til forsiden efter booking er sendt
        Navigation.NavigateTo("/");
    }
}
