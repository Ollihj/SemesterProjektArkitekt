@page "/"
@using Core.Models
@using Blazored.LocalStorage
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject HttpClient Http

<PageTitle>Studio Arkitekt</PageTitle>

<!-- =====================
     NAVIGATION
     Viser logo, links og enten brugerens navn + log ud, eller en log ind-knap
     ===================== -->
<nav class="home-nav">
    <span class="home-logo">ARKITEKT JOHAN BERTHELSEN, MAA</span>

    <!-- Links til de tre primære sider -->
    <div class="home-nav-links">
        <NavLink href="/" Match="NavLinkMatch.All">FORSIDE</NavLink>
        <NavLink href="/projekter">PROJEKTER</NavLink>
        <NavLink href="/booking">KONTAKT</NavLink>
    </div>

    <!-- Hvis brugeren er logget ind vises dashboard-link, navn og log ud-knap, ellers vises log ind-knap -->
    @if (erLoggetInd)
    {
        <div class="home-nav-right">
            <!-- Dashboard-knappen er kun synlig når man er logget ind -->
            <button @onclick='() => Navigation.NavigateTo("/admin")'>DASHBOARD</button>
            <span>@brugerNavn</span>
            <button @onclick="LogUd">LOG UD</button>
        </div>
    }
    else
    {
        <button @onclick='() => Navigation.NavigateTo("/LoginPage")'>LOG IND</button>
    }
</nav>

<!-- =====================
     HERO SEKTION
     Stor indledende sektion øverst på siden
     ===================== -->
<section class="home-hero">
    <h1>Arkitektur med omhu <br />for detaljen</h1>
</section>

<!-- =====================
     INTRO SEKTION
     To-kolonne layout med overskrift til venstre og beskrivende tekst til højre
     ===================== -->
<section class="home-intro">
    <div class="home-intro-left">
        <h2>Arkitektur som<br />skaber værdi</h2>
    </div>
    <div class="home-om-grid">

        <div class="home-om-item">
            <h3 class="home-om-titel">Restaurering med respekt for historien</h3>
            <p class="home-om-tekst">Når jeg restaurerer og transformerer, gør jeg det naturligvis med respekt for den oprindelige arkitektur og byggestil, men samtidig med blik for moderne krav og jeres behov. Jeg arbejder ambitiøst og klogt med historiske bygninger for at skabe en levende kulturarv i den rette balance mellem nyt og gammelt.</p>
        </div>

        <div class="home-om-item">
            <h3 class="home-om-titel">Transformation og renovering</h3>
            <p class="home-om-tekst">Bygninger kan transformeres eller renoveres på mange måder. Jeg tager afsæt i det konkrete projekt, bygherrens ønsker og de givne økonomiske rammer for at finde den optimale vej til en fornyet bygning.</p>
        </div>

        <div class="home-om-item">
            <h3 class="home-om-titel">Bæredygtig boligrenovering</h3>
            <p class="home-om-tekst">Måske ønsker du en mere bæredygtig bolig. Jeg tænker miljøet og bæredygtighed ind i arkitekturen og udarbejder en plan for renoveringen af din bolig i tæt samarbejde med dig som bygherre. Når du renoverer, holder du fast i boligens kvaliteter, samtidig med at du tilføjer nye funktioner — for eksempel nyt køkken, bad eller en ny facade. En renovering forbedrer hverdagens kvalitet og gør dit hjem mere økonomisk og bæredygtigt.</p>
        </div>

        <div class="home-om-item">
            <h3 class="home-om-titel">Kirkerestaurering og kulturarv</h3>
            <p class="home-om-tekst">Jeg arbejder med restaurering af den danske kulturarv i bred forstand og har indgående kendskab til og mange års erfaring med kirkerestaurering. Jeg har et godt samarbejde med menighedsråd og kirkelige myndigheder.</p>
        </div>

    </div>
</section>

<!-- =====================
     PROJEKTER SEKTION
     Viser de 2 nyeste projekter hentet fra databasen
     Klik på et projekt navigerer til projektets detaljeside
     ===================== -->
<section class="home-projekter">
    <p class="home-section-label">UDVALGTE PROJEKTER</p>

    @if (projekter == null)
    {
        <!-- Vises mens projekter hentes fra serveren -->
        <p>Henter projekter...</p>
    }
    else if (projekter.Count == 0)
    {
        <!-- Vises hvis der ingen projekter er i databasen endnu -->
        <p>Ingen projekter endnu.</p>
    }
    else
    {
        <!-- Viser kun de 2 første projekter på forsiden med .Take(2) -->
        <div class="home-projekter-grid">
            @foreach (var projekt in projekter.Take(2))
            {
                <!-- Klik på kortet navigerer til projektets detaljeside -->
                <div class="home-projekt-card" @onclick='() => Navigation.NavigateTo($"/projekter/{projekt.Id}")'>
                    <div class="home-projekt-billede">
                        @if (projekt.Billeder.Any())
                        {
                            <!-- Henter det første billede fra serveren via download-endpointet -->
                            <img src="@($"http://localhost:5000/api/file/download/{projekt.Billeder.First().FileName}")" alt="@projekt.Navn" />
                        }
                        else
                        {
                            <span>Intet billede</span>
                        }
                    </div>
                    <p>@projekt.Navn — @projekt.År</p>
                </div>
            }
        </div>
    }

    <!-- Knap der navigerer til den fulde portfolioside -->
    <div class="home-alle-projekter">
        <button @onclick='() => Navigation.NavigateTo("/projekter")'>SE ALLE PROJEKTER →</button>
    </div>
</section>

<!-- =====================
     CTA SEKTION (Call To Action)
     Opfordrer besøgende til at tage kontakt
     ===================== -->
<section class="home-cta">
    <div class="home-cta-left">
        <h2>Lad os skabe noget<br />bemærkelsesværdigt<br />sammen</h2>
    </div>
    <div class="home-cta-right">
        <p>Uanset om du har en konkret vision eller søger inspiration, er vi klar til at hjælpe dig med at realisere dit projekt.</p>
        <button @onclick='() => Navigation.NavigateTo("/booking")'>BOOK KONSULTATION →</button>
    </div>
</section>

@code {
    // Styrer om login-knap eller brugernavn/log ud vises i navigationen
    private bool erLoggetInd = false;
    private string brugerNavn = "";

    // Listen af projekter hentet fra API'et — null mens de hentes, tom liste hvis ingen findes
    private List<Projekt>? projekter;

    // Kører automatisk når siden indlæses
    protected override async Task OnInitializedAsync()
    {
        // Henter brugeroplysninger fra LocalStorage for at tjekke om man er logget ind
        var userId = await LocalStorage.GetItemAsync<int?>("userId");
        brugerNavn = await LocalStorage.GetItemAsync<string>("userName") ?? "";

        // Brugeren anses som logget ind hvis der findes et gyldigt userId i LocalStorage
        erLoggetInd = userId != null && userId > 0;

        // Henter alle projekter fra API'et — ved fejl bruges en tom liste så siden ikke crasher
        try
        {
            projekter = await Http.GetFromJsonAsync<List<Projekt>>("api/projekt") ?? new();
        }
        catch
        {
            projekter = new List<Projekt>();
        }
    }

    // Logger brugeren ud ved at slette alle brugerdata fra LocalStorage
    private async Task LogUd()
    {
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userName");
        await LocalStorage.RemoveItemAsync("userRole");

        // Opdaterer UI så log ind-knappen vises igen uden at genindlæse siden
        erLoggetInd = false;
        brugerNavn = "";
    }
}
